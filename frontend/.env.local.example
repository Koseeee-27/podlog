# フロントエンド用の環境変数テンプレート
# このファイルを .env.local にコピーして値を設定してください:
#   cp .env.local.example .env.local

# Supabase
# Supabase ダッシュボード → Settings → API からコピー
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# サイト URL（metadata の metadataBase に使用。og:image / canonical の
# 絶対 URL 解決に使われる）。
# ローカル開発は http://localhost:3000、本番は https://<本番ドメイン> を設定する。
# Netlify では Production と Deploy Preview で**別々の値**を設定すること。
# 未設定時は layout.tsx 側で http://localhost:3000 にフォールバックするが、
# Preview ビルドで未設定のまま SNS スクレイパがアクセスすると localhost の
# og:image / canonical が外部に混入するため必ず設定する。
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry
# DSN は Sentry ダッシュボード → Project → Client Keys (DSN) からコピー。
# 開発時は空でも動作する（SDK が no-op になる）。
NEXT_PUBLIC_SENTRY_DSN=
# 環境名のラベル。Sentry は `NODE_ENV === "production"` かつこの値が "production" の
# ときだけ送信を有効化する（Netlify の Deploy Preview では NODE_ENV が production に
# なるため、この変数で preview を "preview" に設定して無料枠の消費を防ぐ）。
# `app/robots.ts` もこの値が "production" のときだけ `allow: "/"` にする。
NEXT_PUBLIC_SENTRY_ENV=production

# Sitemap API Token
# `app/sitemap.ts` から BE の `/sitemap/*` を呼ぶときの Bearer トークン。
# BE 側の SITEMAP_API_TOKEN と**完全に同じ値**を設定すること（pre-shared token）。
# `NEXT_PUBLIC_` プレフィックス無し = サーバーサイド専用でクライアントバンドルには
# 含まれない。
# - 開発時: 空のままでよい（BE 側 middleware が development では認証スキップ）。
# - 本番:   `openssl rand -base64 32` で生成した値を Cloud Run と Netlify の両方に
#           同じ値で設定する。詳細は workspace の docs/deploy.md 参照。
SITEMAP_API_TOKEN=
