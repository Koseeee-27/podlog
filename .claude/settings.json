{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.development)",
      "Bash(cat */.env)",
      "Bash(cat */.env.local)",
      "Bash(head */.env)",
      "Bash(head */.env.local)",
      "Bash(tail */.env)",
      "Bash(tail */.env.local)"
    ]
  }
}
