#docker-compose.yml で使用される環境変数
# このファイルを .env にコピーして値を設定してください:
#   cp .env.example .env

# Supabase プロジェクト URL
# Supabase ダッシュボード → Settings → API → Project URL からコピー
SUPABASE_URL=https://your-project.supabase.co

# Supabase サービスロールキー（サーバーサイド専用）
# Supabase ダッシュボード → Settings → API → Service role key からコピー
# アバター画像の Storage アップロードに使用する。フロントエンドには公開しないこと
SUPABASE_SERVICE_KEY=your-service-role-key-here

# PostgreSQL 接続情報（ローカル開発用）
# 本番環境では必ず強力なパスワードに変更してください
POSTGRES_DB=podlog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 管理者ユーザー ID（カンマ区切り）
# /admin API にアクセスできるユーザーの Supabase Auth UUID を指定
# ADMIN_USER_IDS=your-user-uuid-here
