# ローカル開発用の環境変数テンプレート（Docker を使わず直接実行する場合）
# このファイルを .env にコピーして使ってください:
#   cp .env.example .env

PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/podlog?sslmode=disable
CORS_ALLOW_ORIGINS=http://localhost:3000
APP_ENV=development

# Supabase プロジェクト URL
# Supabase ダッシュボード → Settings → API → Project URL からコピー
SUPABASE_URL=https://your-project.supabase.co
