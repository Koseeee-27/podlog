# ローカル開発用の環境変数テンプレート（Docker を使わず直接実行する場合）
# このファイルを .env にコピーして使ってください:
#   cp .env.example .env

PORT=8080

# データベース接続情報（個別パラメータ）
# アプリ内で安全にDSNを組み立てるため、DATABASE_URL ではなく個別に指定する。
# パスワードに @, :, / 等の特殊文字が含まれていても正しく接続できる。
# 注意: 本番環境では必ず強力なパスワードに変更してください
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=podlog
DB_SSLMODE=disable

CORS_ALLOW_ORIGINS=http://localhost:3000
APP_ENV=development

# Supabase プロジェクト URL
# Supabase ダッシュボード → Settings → API → Project URL からコピー
SUPABASE_URL=https://your-project.supabase.co
